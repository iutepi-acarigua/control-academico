<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Breadcrumbs - Adjusted for Odoo 19 -->
    <template id="portal_my_home_menu_university" inherit_id="portal.portal_breadcrumbs" priority="30">
        <xpath expr="//ol" position="inside">
            <li t-if="page_name == 'application'" class="breadcrumb-item active">
                My Inscriptions
            </li>
        </xpath>
    </template>

    <!-- Portal Home Section -->
    <template id="portal_my_home_university" inherit_id="portal.portal_my_home" priority="30">
        <!-- 1. Quick action buttons in the banner -->
        <xpath expr="//div[hasclass('o_portal_docs')]" position="before">
            <div class="row mb-4 mt-2">
                <div class="col-12">
                    <div class="card border-0 shadow-sm bg-primary text-white p-4 portal-university-banner">
                        <div class="d-flex align-items-center justify-content-between flex-wrap gap-3">
                            <div>
                                <h3 class="mb-1 fw-bold">Welcome to the Admissions Process!</h3>
                                <p class="mb-0 opacity-75">Manage your applications from here.</p>
                            </div>
                            <div class="d-flex gap-2">
                                <a href="/my/applications" class="btn btn-outline-light fw-bold px-4">
                                    <i class="fa fa-list-ul me-1"/> View my applications
                                </a>
                                <a href="/enrollment" class="btn btn-light fw-bold px-4 text-primary">
                                    <i class="fa fa-plus-circle me-1"/> New Inscription
                                </a>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </xpath>

        <!-- 2. Inscriptions Card (Always Visible) -->
        <xpath expr="//div[hasclass('o_portal_docs')]" position="inside">
            <a href="/my/applications" title="My Inscriptions" class="list-group-item list-group-item-action d-flex align-items-center justify-content-between border-0 shadow-sm mb-2 rounded p-3">
                <div class="d-flex align-items-center">
                    <div class="bg-primary-light p-2 rounded me-3">
                        <i class="fa fa-graduation-cap fa-2x text-primary"/>
                    </div>
                    <div>
                        <h5 class="mb-0 fw-bold text-dark">My Inscriptions</h5>
                        <small class="text-muted">Check the status of your university procedures</small>
                    </div>
                </div>
                <span class="badge rounded-pill bg-primary" t-esc="application_count or '0'"/>
            </a>
        </xpath>
    </template>

    <!-- Portal List View -->
    <template id="portal_my_applications" name="My Applications">
        <t t-call="portal.portal_layout">
            <div class="row mt-4 mb-3 align-items-center justify-content-between">
                <div class="col-12 col-md-6">
                    <h2 class="fw-bold text-primary mb-0">My Enrollment Applications</h2>
                </div>
                <div class="col-12 col-md-auto mt-3 mt-md-0">
                    <a href="/enrollment" class="btn btn-primary btn-lg shadow-sm">
                        <i class="fa fa-plus-circle me-1"/> New Application
                    </a>
                </div>
            </div>

            <t t-if="not applications">
                <div class="card border-0 shadow-sm p-5 text-center">
                    <div class="card-body">
                        <i class="fa fa-folder-open-o fa-4x text-muted mb-3 opacity-50"/>
                        <h4 class="text-muted">No applications found</h4>
                        <p class="mb-4">Your future starts here. Click the button above to enroll.</p>
                    </div>
                </div>
            </t>

            <t t-if="applications">
                <div class="card border-0 shadow-sm overflow-hidden">
                    <table class="table table-hover mb-0">
                        <thead class="bg-light">
                            <tr>
                                <th class="ps-4">Application #</th>
                                <th>University Career</th>
                                <th>Date</th>
                                <th class="text-end pe-4">Status</th>
                            </tr>
                        </thead>
                        <tbody>
                            <t t-foreach="applications" t-as="app">
                                <tr>
                                    <td class="ps-4 align-middle">
                                        <span class="fw-bold text-primary">#<t t-esc="app.id"/></span>
                                    </td>
                                    <td class="align-middle">
                                        <span class="d-block fw-semibold text-dark" t-field="app.career_id.name"/>
                                        <small class="text-muted" t-field="app.modality_id.name"/>
                                    </td>
                                    <td class="align-middle text-muted">
                                        <span t-field="app.create_date" t-options="{'widget': 'date'}"/>
                                    </td>
                                    <td class="text-end pe-4 align-middle">
                                        <span t-if="app.state == 'draft'" class="badge rounded-pill bg-secondary px-3 py-2">Draft</span>
                                        <span t-if="app.state == 'sent'" class="badge rounded-pill bg-info text-white px-3 py-2">Sent</span>
                                        <span t-if="app.state == 'validated'" class="badge rounded-pill bg-success px-3 py-2">Validated</span>
                                        <span t-if="app.state == 'rejected'" class="badge rounded-pill bg-danger px-3 py-2">Rejected</span>
                                    </td>
                                </tr>
                            </t>
                        </tbody>
                    </table>
                </div>
            </t>
        </t>
    </template>
</odoo>
