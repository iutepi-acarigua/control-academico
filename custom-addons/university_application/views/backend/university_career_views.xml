<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Vista Lista de Carreras -->
    <record id="view_university_career_list" model="ir.ui.view">
        <field name="name">university.career.list</field>
        <field name="model">university.career</field>
        <field name="arch" type="xml">
            <list string="University Careers">
                <field name="name"/>
                <field name="description"/>
            </list>
        </field>
    </record>

    <!-- Vista Formulario de Carreras -->
    <record id="view_university_career_form" model="ir.ui.view">
        <field name="name">university.career.form</field>
        <field name="model">university.career</field>
        <field name="arch" type="xml">
            <form string="University Career">
                <sheet>
                    <div class="oe_title">
                        <label for="name" class="oe_edit_only"/>
                        <h1><field name="name" placeholder="e.g. Computer Science"/></h1>
                    </div>
                    <group>
                        <field name="description"/>
                    </group>
                    <notebook>
                        <page string="Curriculum" name="subjects">
                            <field name="subject_ids">
                                <list editable="bottom">
                                    <field name="period"/>
                                    <field name="subject_id"/>
                                    <field name="is_elective"/>
                                </list>
                            </field>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <!-- Vista Lista de Modalidades -->
    <record id="view_university_modality_list" model="ir.ui.view">
        <field name="name">university.modality.list</field>
        <field name="model">university.modality</field>
        <field name="arch" type="xml">
            <list string="University Modalities">
                <field name="name"/>
                <field name="description"/>
            </list>
        </field>
    </record>

    <!-- Vista Formulario de Modalidades -->
    <record id="view_university_modality_form" model="ir.ui.view">
        <field name="name">university.modality.form</field>
        <field name="model">university.modality</field>
        <field name="arch" type="xml">
            <form string="University Modality">
                <sheet>
                    <group>
                        <field name="name"/>
                        <field name="description"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>
</odoo>
