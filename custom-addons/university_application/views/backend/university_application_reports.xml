<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Acción para generar el Reporte PDF -->
    <record id="action_report_university_application" model="ir.actions.report">
        <field name="name">Registration Fiche</field>
        <field name="model">university.application</field>
        <field name="report_type">qweb-pdf</field>
        <field name="report_name">university_application.report_application_fiche</field>
        <field name="report_file">university_application.report_application_fiche</field>
        <field name="print_report_name">'Fiche_%s' % (object.name)</field>
        <field name="binding_model_id" ref="model_university_application"/>
        <field name="binding_type">report</field>
    </record>
</odoo>
