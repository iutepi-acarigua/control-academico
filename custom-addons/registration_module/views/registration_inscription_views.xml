<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- View registration.inscription View List -->
    <record id="view_registration_inscription_list" model="ir.ui.view">
        <field name="name">view.registration.inscription.list</field>
        <field name="model">registration.inscription</field>
        <field name="arch" type="xml">
            <list>
                <field name="name"/>
            </list>
        </field>
    </record>

    <!-- View registration.inscription form -->
    <record id="view_registration_inscription_form" model="ir.ui.view">
        <field name="name">view.registration.inscription.form</field>
        <field name="model">registration.inscription</field>
        <field name="arch" type="xml">
            <form string="Registration Inscription">
                <sheet>
                    <div class="oe_title">
                        <label for="name"/>
                        <h1>
                            <field name="name" placeholder="Name..."/>
                        </h1>
                    </div>
                </sheet>
            </form>
        </field>
    </record>

    <!-- View registration.inscription search -->
    <record id="view_registration_inscription_search" model="ir.ui.view">
        <field name="name">view.registration.inscription.search</field>
        <field name="model">registration.inscription</field>
        <field name="arch" type="xml">
            <search>
                <field name="name"/>
            </search>
        </field>
    </record>

    <!-- Action registration.inscription -->
    <record id="action_registration_inscription" model="ir.actions.act_window">
        <field name="name">Registration Inscription</field>
        <field name="type">ir.actions.act_window</field>
        <field name="res_model">registration.inscription</field>
        <field name="view_mode">list,form</field>
        <field name="domain">[]</field>
        <field name="context">{}</field>
        <field name="help" type="html">
            <p class="oe_view_nocontent_create">
                There is no examples click here to add new Registration Inscription.
            </p>
        </field>
    </record>

</odoo>
